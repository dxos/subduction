{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": "./dist",
    "rootDir": "./js",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "noImplicitAny": false,
    "strictNullChecks": false
  },
  "include": [
    "js/**/*.ts",
    "js/**/*.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "test"
  ]
}