{
  "name": "@dxos/automerge-subduction",
  "version": "0.1.2",
  "description": "Unified WASM bindings for Automerge documents and Subduction replication",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/cjs/node.cjs",
  "scripts": {
    "build": "rm -rf dist && node ./build_wasm.mjs && node ./build_js.js",
    "test": "vitest --run --passWithNoTests",
    "typecheck": "tsc --noEmit -p tsconfig.test.json"
  },
  "keywords": [
    "automerge",
    "crdt",
    "subduction",
    "sync",
    "wasm"
  ],
  "author": "Alex Good <alex@patternist.xyz>, Brooklyn Zelenka <hello@brooklynzelenka.com>",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxos/automerge-subduction",
    "directory": "automerge_subduction_wasm"
  },
  "homepage": "https://github.com/dxos/automerge-subduction",
  "bugs": {
    "url": "https://github.com/dxos/automerge-subduction/issues"
  },
  "type": "module",
  "module": "./dist/esm/bundler.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "./dist/esm/node.js",
    "./dist/esm/web.js",
    "./dist/esm/workerd.js",
    "./dist/esm/bundler.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "workerd": {
        "import": "./dist/esm/workerd.js",
        "require": "./dist/cjs/web.cjs"
      },
      "node": {
        "import": "./dist/esm/node.js",
        "require": "./dist/cjs/node.cjs"
      },
      "browser": {
        "import": "./dist/esm/bundler.js",
        "require": "./dist/cjs/web.cjs"
      },
      "import": "./dist/esm/web.js",
      "require": "./dist/cjs/web.cjs"
    },
    "./slim": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/slim.js",
      "require": "./dist/cjs/slim.cjs"
    },
    "./wasm": "./dist/automerge-subduction.wasm",
    "./automerge.wasm": "./dist/automerge-subduction.wasm",
    "./wasm-base64": {
      "import": "./dist/esm/wasm-base64.js",
      "require": "./dist/cjs/wasm-base64.cjs"
    },
    "./iife": "./dist/iife/index.js",
    "./debug": {
      "types": "./dist/index.d.ts",
      "workerd": {
        "import": "./dist/esm/debug-workerd.js",
        "require": "./dist/cjs/debug-web.cjs"
      },
      "node": {
        "import": "./dist/esm/debug-node.js",
        "require": "./dist/cjs/debug-node.cjs"
      },
      "browser": {
        "import": "./dist/esm/debug-bundler.js",
        "require": "./dist/cjs/debug-web.cjs"
      },
      "import": "./dist/esm/debug-web.js",
      "require": "./dist/cjs/debug-web.cjs"
    },
    "./debug/slim": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/debug-slim.js",
      "require": "./dist/cjs/debug-slim.cjs"
    },
    "./debug/wasm": "./dist/automerge-subduction-debug.wasm",
    "./debug/wasm-base64": {
      "import": "./dist/esm/debug-wasm-base64.js",
      "require": "./dist/cjs/debug-wasm-base64.cjs"
    },
    "./debug/iife": "./dist/iife/debug.js"
  },
  "devDependencies": {
    "@types/node": "^22.17.2",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.2",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0"
    }
  }
}